{
  "name": "system-performance",
  "publisher": "bubablue00",
  "displayName": "System Performance",
  "description": "Real-time system performance monitoring with animated CPU, memory, and resource usage graphs in VSCode",
  "version": "0.1.1",
  "icon": "icon.png",
  "keywords": [
    "system",
    "performance",
    "monitoring",
    "cpu",
    "memory",
    "resources",
    "graph",
    "chart",
    "status",
    "metrics"
  ],
  "engines": {
    "vscode": "^1.102.0"
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": false,
      "description": "This extension requires system access to monitor performance metrics."
    }
  },
  "categories": [
    "Other",
    "Visualization",
    "Debuggers"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/bubablue/system-performance-extension.git"
  },
  "bugs": {
    "url": "https://github.com/bubablue/system-performance-extension/issues"
  },
  "homepage": "https://github.com/bubablue/system-performance-extension#readme",
  "license": "MIT",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "system-performance.showGraph",
        "title": "Show System Graph"
      },
      {
        "command": "system-performance.toggleGraph",
        "title": "Toggle System Graph"
      },
      {
        "command": "system-performance.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "system-performance.toggleMonitoring",
        "title": "Toggle Monitoring",
        "icon": "$(eye)"
      },
      {
        "command": "system-performance.resetPermissions",
        "title": "Reset System Permissions"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "systemResourcesView",
          "name": "System Resources",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "system-performance.refresh",
          "when": "view == systemResourcesView",
          "group": "navigation"
        },
        {
          "command": "system-performance.toggleMonitoring",
          "when": "view == systemResourcesView",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "System Graph",
      "properties": {
        "systemGraph.showCpu": {
          "type": "boolean",
          "default": true,
          "description": "Show CPU usage bar"
        },
        "systemGraph.showMemory": {
          "type": "boolean",
          "default": true,
          "description": "Show memory usage bar"
        },
        "systemGraph.showVscodeCpu": {
          "type": "boolean",
          "default": true,
          "description": "Show VS Code CPU usage bar"
        },
        "systemGraph.showVscodeMemory": {
          "type": "boolean",
          "default": true,
          "description": "Show VS Code memory usage bar"
        },
        "systemGraph.showNetwork": {
          "type": "boolean",
          "default": true,
          "description": "Show network I/O bar"
        },
        "systemGraph.showLatency": {
          "type": "boolean",
          "default": true,
          "description": "Show network latency bar"
        },
        "systemGraph.statusBar.showCpu": {
          "type": "boolean",
          "default": true,
          "description": "Show system CPU usage in the status bar"
        },
        "systemGraph.statusBar.showMemory": {
          "type": "boolean",
          "default": true,
          "description": "Show system memory usage in the status bar"
        },
        "systemGraph.statusBar.showVscodeCpu": {
          "type": "boolean",
          "default": true,
          "description": "Show VS Code CPU usage in the status bar"
        },
        "systemGraph.statusBar.showVscodeMemory": {
          "type": "boolean",
          "default": true,
          "description": "Show VS Code memory usage in the status bar"
        },
        "systemGraph.statusBar.showNetwork": {
          "type": "boolean",
          "default": true,
          "description": "Show network I/O in the status bar"
        },
        "systemGraph.statusBar.showDisk": {
          "type": "boolean",
          "default": true,
          "description": "Show disk I/O in the status bar"
        },
        "systemGraph.statusBar.showUptime": {
          "type": "boolean",
          "default": true,
          "description": "Show system uptime in the status bar"
        },
        "systemGraph.statusBar.showLatency": {
          "type": "boolean",
          "default": true,
          "description": "Show network latency in the status bar (remote host when connected remotely, internet latency when local)"
        },
        "systemGraph.latency.warningThreshold": {
          "type": "number",
          "default": 200,
          "minimum": 10,
          "maximum": 5000,
          "description": "Latency threshold in ms above which a warning highlight is shown"
        },
        "systemGraph.latency.targetHost": {
          "type": "string",
          "default": "",
          "description": "Custom host to measure latency against (e.g. 'myserver.com'). Leave empty to use default internet latency (ping to 8.8.8.8)"
        },
        "systemGraph.latency.targetPort": {
          "type": "number",
          "default": 443,
          "minimum": 1,
          "maximum": 65535,
          "description": "Port to use when measuring latency to a custom target host"
        },
        "systemGraph.statusBarEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable status bar monitoring"
        },
        "systemGraph.updateInterval": {
          "type": "number",
          "default": 4000,
          "minimum": 500,
          "maximum": 10000,
          "description": "Update interval in milliseconds"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "npm run compile && node ./out/test/e2e/runTests.js",
    "test:e2e": "npm run compile && node ./out/test/e2e/runTests.js",
    "package": "vsce package",
    "generate-changelog": "github_changelog_generator -u bubablue -p system-performance-extension -t $GITHUB_TOKEN"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "25.5.0",
    "@types/vscode": "^1.102.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^10.0.3",
    "typescript": "^5.9.3",
    "glob": "^13.0.6",
    "mocha": "^11.7.5"
  },
  "dependencies": {
    "systeminformation": "^5.31.4"
  }
}
